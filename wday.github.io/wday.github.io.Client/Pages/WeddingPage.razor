@page "/wedding/{Slug}"
@inject IJSRuntime Js
@inject NavigationManager Nav

<PageTitle>@WeddingContent.CoupleNames — @WeddingContent.DateDisplay</PageTitle>

@if (!_skipOpening)
{
    <OpeningInvitation OnOpened="HandleOpened" />
}

@if (_opened)
{
    <main>
        <WeddingHero />
        <WeddingIntroduction />
        <CoupleSection />
        <WeddingDateSection />
        <WeddingCountdown />
        <WeddingEvents />
        <LoveStory />
        <WeddingGallery />
        <CinematicQuote />
        <RsvpSection Slug="@Slug" />
        <GuestWishes Slug="@Slug" />
        <WeddingGift />
        <WeddingFinal />
    </main>
}

<WeddingMusicPlayer @ref="_music" />

@code {
    [Parameter] public string Slug { get; set; } = WeddingContent.Slug;

    private bool _opened;
    private bool _skipOpening;
    private bool _petalsStarted;
    private WeddingMusicPlayer? _music;

    protected override void OnInitialized()
    {
        // ?open=1 bỏ qua màn mở thiệp (dùng khi khách quay lại xem / khi test)
        var query = new Uri(Nav.Uri).Query;
        if (query.Contains("open=1", StringComparison.OrdinalIgnoreCase))
        {
            _skipOpening = true;
            _opened = true;
        }
    }

    private async Task HandleOpened()
    {
        _opened = true;
        StateHasChanged();

        await Js.InvokeVoidAsync("wedding.scrollToTop");
        if (_music is not null)
        {
            await _music.StartAsync(); // nhạc bắt đầu sau cú chạm MỞ THIỆP (thoả autoplay policy)
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Gọi sau mỗi render để observe các section mới xuất hiện
        await Js.InvokeVoidAsync("wedding.initReveal");

        if (firstRender && _opened)
        {
            // Deep-link dạng /wedding/slug?open=1#gallery — cuộn tới section sau khi render
            await Js.InvokeVoidAsync("wedding.scrollToFragment");
        }

        if (_opened && !_petalsStarted)
        {
            _petalsStarted = true;
            await Js.InvokeVoidAsync("wedding.initPetals"); // cánh hoa rơi sau khi mở thiệp
        }
    }
}
