@* Section 5 — Ngày cưới, typography lớn kiểu tạp chí *@

<section id="date" class="wd-section wd-date">
    <div class="wd-container">
        <div class="wd-date-month" data-reveal="fade-up">October</div>
        <div class="wd-date-day" data-reveal="fade-up" data-delay="1">18</div>
        <div class="wd-date-year" data-reveal="fade-up" data-delay="2">2026</div>
        <div class="wd-date-weekday" data-reveal="fade-up" data-delay="2">Sunday</div>
        <div class="wd-label" data-reveal="fade-up" data-delay="3">Save The Date</div>
    </div>
</section>
