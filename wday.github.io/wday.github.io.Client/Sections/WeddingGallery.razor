@* Section 9 — Gallery editorial masonry + fullscreen lightbox.
   Nhịp điệu ảnh (thứ tự, hình dạng, ảnh feature) khai báo trong WeddingImages.Gallery. *@
@inject IJSRuntime Js
@implements IAsyncDisposable

<section class="wd-section wd-gallery">
    <div class="wd-container">
        <div class="wd-label" data-reveal="fade-up">Our Moments</div>
        <h2 class="wd-heading" data-reveal="fade-up" data-delay="1">Khoảnh khắc của chúng mình</h2>

        <div class="wd-gallery-grid">
            @for (var i = 0; i < Images.Length; i++)
            {
                var index = i;
                var img = Images[index];
                <button type="button"
                        class="wd-gallery-item shape-@img.Shape @(img.Feature ? "is-feature" : null)"
                        data-reveal="fade-up"
                        @onclick="() => OpenLightboxAsync(index)"
                        aria-label="Xem ảnh: @img.Alt">
                    <img src="@img.Src" alt="@img.Alt" loading="lazy" />
                </button>
            }
        </div>
    </div>
</section>

@if (_lightboxIndex is { } current)
{
    var img = Images[current];
    <div class="wd-lightbox" id="wd-lightbox" @onclick="CloseLightboxAsync">
        <img src="@img.Src" alt="@img.Alt" @onclick:stopPropagation />

        <button type="button" class="wd-lb-btn wd-lb-prev" aria-label="Ảnh trước"
                @onclick="() => MoveAsync(-1)" @onclick:stopPropagation>
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
                <path d="M14 3 L 6 11 L 14 19" />
            </svg>
        </button>
        <button type="button" class="wd-lb-btn wd-lb-next" aria-label="Ảnh sau"
                @onclick="() => MoveAsync(1)" @onclick:stopPropagation>
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
                <path d="M8 3 L 16 11 L 8 19" />
            </svg>
        </button>
        <button type="button" class="wd-lb-close" aria-label="Đóng" @onclick="CloseLightboxAsync" @onclick:stopPropagation>
            <svg width="20" height="20" viewBox="0 0 20 20" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
                <path d="M3 3 L 17 17 M17 3 L 3 17" />
            </svg>
        </button>

        <div class="wd-lb-counter">@(current + 1) / @Images.Length</div>
    </div>
}

@code {
    private static WeddingImages.GalleryImage[] Images => WeddingImages.Gallery;

    private int? _lightboxIndex;
    private bool _swipeAttached;
    private DotNetObjectReference<WeddingGallery>? _selfRef;

    private Task OpenLightboxAsync(int index)
    {
        _lightboxIndex = index;
        _swipeAttached = false;
        return Task.CompletedTask; // swipe/keyboard gắn ở OnAfterRenderAsync khi lightbox đã có trong DOM
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_lightboxIndex is not null && !_swipeAttached)
        {
            _swipeAttached = true;
            _selfRef ??= DotNetObjectReference.Create(this);
            await Js.InvokeVoidAsync("wedding.lightboxAttachById", "wd-lightbox", _selfRef);
        }
    }

    [JSInvokable]
    public async Task OnLightboxSwipe(string action)
    {
        switch (action)
        {
            case "next": await MoveAsync(1); break;
            case "prev": await MoveAsync(-1); break;
            case "close": await CloseLightboxAsync(); break;
        }
        StateHasChanged();
    }

    private Task MoveAsync(int delta)
    {
        if (_lightboxIndex is { } i)
        {
            _lightboxIndex = (i + delta + Images.Length) % Images.Length;
        }
        return Task.CompletedTask;
    }

    private async Task CloseLightboxAsync()
    {
        _lightboxIndex = null;
        _swipeAttached = false;
        await Js.InvokeVoidAsync("wedding.lightboxDetach");
    }

    public async ValueTask DisposeAsync()
    {
        _selfRef?.Dispose();
        try { await Js.InvokeVoidAsync("wedding.lightboxDetach"); }
        catch { /* trang đang unload */ }
    }
}
