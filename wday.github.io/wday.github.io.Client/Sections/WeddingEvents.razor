@* Section 7 — Sự kiện cưới, layout editorial ảnh xen kẽ trái phải *@

<section id="events" class="wd-section wd-events">
    <div class="wd-container">
        <div class="wd-label" data-reveal="fade-up">Wedding Events</div>
        <h2 class="wd-heading" data-reveal="fade-up" data-delay="1">Hân hạnh được đón tiếp</h2>

        <div class="wd-events-list">
            @foreach (var ev in WeddingContent.Events)
            {
                <article class="wd-event">
                    <div class="wd-event-photo wd-image-reveal" data-reveal="fade-in">
                        <img src="@ev.Image" alt="@ev.Title" loading="lazy" />
                    </div>
                    <div class="wd-event-text" data-reveal="fade-up">
                        <h3 class="wd-event-title">@ev.Title</h3>
                        <div class="wd-event-time">@ev.Date — @ev.Time</div>
                        <div class="wd-event-venue">@ev.Venue</div>
                        <p class="wd-event-address">@ev.Address</p>
                        <a class="wd-map-link" href="@ev.MapUrl" target="_blank" rel="noopener">
                            <svg width="13" height="15" viewBox="0 0 13 15" fill="none" stroke="currentColor" stroke-width="1.1" aria-hidden="true">
                                <path d="M6.5 14 C 6.5 14, 12 8.8, 12 5.5 A 5.5 5.5 0 1 0 1 5.5 C 1 8.8, 6.5 14, 6.5 14 Z" />
                                <circle cx="6.5" cy="5.5" r="2" />
                            </svg>
                            Xem bản đồ
                        </a>
                    </div>
                </article>
            }
        </div>
    </div>
</section>
