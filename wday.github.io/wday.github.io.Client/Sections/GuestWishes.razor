@* Section 12 — Lời chúc của khách, kiểu trích dẫn tạp chí.
   Có mẫu câu gợi ý, lọc từ thô tục, animation khi lời chúc xuất hiện. *@
@inject WeddingApiClient Api
@inject IJSRuntime Js

<section id="wishes" class="wd-section wd-wishes">
    <div class="wd-container">
        <div class="wd-label" data-reveal="fade-up">Guest Wishes</div>
        <h2 class="wd-heading" data-reveal="fade-up" data-delay="1">Words from our favorite people</h2>

        <div class="wd-wish-list">
            @if (_wishes.Count == 0)
            {
                <p class="wd-wishes-empty" data-reveal="fade-up">
                    Hãy là người đầu tiên gửi lời chúc tới hai chúng mình nhé!
                </p>
            }
            else
            {
                var delay = 0;
                @foreach (var wish in _wishes)
                {
                    <blockquote class="wd-wish @(wish == _justSent ? "wd-wish--new" : null)"
                                data-reveal="fade-up" data-delay="@(Math.Min(delay++, 3))">
                        <p class="wd-wish-content">@wish.Content</p>
                        <footer class="wd-wish-name">@wish.GuestName</footer>
                    </blockquote>
                }
            }
        </div>

        @if (_sent)
        {
            <div class="wd-form-success" role="status">
                <p>Cảm ơn lời chúc dễ thương của bạn!</p>
            </div>
        }
        else
        {
            <EditForm Model="_model" OnValidSubmit="SubmitAsync" class="wd-form">
                <DataAnnotationsValidator />

                <div class="wd-field">
                    <label for="wish-name">Tên của bạn</label>
                    <InputText id="wish-name" @bind-Value="_model.GuestName" placeholder="Nguyễn Văn A" />
                    <ValidationMessage For="() => _model.GuestName" class="wd-form-error" />
                </div>

                <div class="wd-field">
                    <label for="wish-content">Lời chúc</label>
                    <InputTextArea id="wish-content" @bind-Value="_model.Content" placeholder="Chúc hai bạn trăm năm hạnh phúc…" />
                    <ValidationMessage For="() => _model.Content" class="wd-form-error" />
                </div>

                @* Mẫu câu gợi ý — chạm để dùng *@
                <div class="wd-wish-samples">
                    <span class="wd-wish-samples-label">Gợi ý nhanh:</span>
                    @foreach (var sample in SampleWishes)
                    {
                        <button type="button" class="wd-wish-chip" @onclick="() => UseSample(sample)">@sample</button>
                    }
                </div>

                <button type="submit" class="wd-submit-btn" disabled="@_sending">
                    @(_sending ? "Đang gửi…" : "Gửi lời chúc")
                </button>

                @if (_profanity)
                {
                    <p class="wd-form-error">Lời chúc có từ ngữ chưa phù hợp với ngày vui, bạn chỉnh lại giúp mình nhé 💕</p>
                }
                else if (_error)
                {
                    <p class="wd-form-error">Không gửi được, bạn thử lại giúp mình nhé.</p>
                }
            </EditForm>
        }
    </div>
</section>

@code {
    [Parameter] public string Slug { get; set; } = WeddingContent.Slug;

    private static readonly string[] SampleWishes =
    [
        "Chúc hai bạn trăm năm hạnh phúc, đầu bạc răng long! 💕",
        "Chúc mừng đám cưới! Mong hai bạn mãi yêu thương nhau như ngày đầu.",
        "Chúc anh chị về chung một nhà luôn ngập tiếng cười và yêu thương.",
        "Chúc hai vợ chồng son hạnh phúc viên mãn, sớm có tin vui!",
    ];

    private GuestWishDto _model = new();
    private List<GuestWishDto> _wishes = [];
    private GuestWishDto? _justSent;
    private bool _sending, _sent, _error, _profanity;

    protected override async Task OnInitializedAsync()
        => _wishes = await Api.GetWishesAsync(Slug);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Danh sách lời chúc load async sau khi trang render — tự observe lại
        // để các phần tử data-reveal mới xuất hiện có animation.
        await Js.InvokeVoidAsync("wedding.initReveal");
    }

    private void UseSample(string sample)
    {
        _model.Content = sample;
        _profanity = false;
    }

    private async Task SubmitAsync()
    {
        _error = false;
        _profanity = ProfanityFilter.ContainsProfanity(_model.Content)
                  || ProfanityFilter.ContainsProfanity(_model.GuestName);
        if (_profanity) return;

        _sending = true;
        try
        {
            _sent = await Api.SendWishAsync(Slug, _model);
            if (_sent)
            {
                _justSent = _model;
                _wishes.Insert(0, _model); // lời chúc mới hiện ngay đầu danh sách kèm animation
                _model = new();
            }
            else
            {
                _error = true;
            }
        }
        catch
        {
            _error = true;
        }
        finally
        {
            _sending = false;
        }
    }
}
