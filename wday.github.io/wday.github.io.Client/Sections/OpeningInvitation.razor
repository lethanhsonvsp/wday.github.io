@* Section 1 — Màn hình mở thiệp toàn màn hình *@

<div class="wd-opening @(_closed ? "is-closed" : null)" aria-hidden="@_closed">
    <div class="wd-opening-bg" style="background-image:url('@WeddingImages.OpeningBackground')"></div>
    <div class="wd-opening-content">
        <div class="wd-label">Save The Date</div>
        <h1 class="wd-opening-names">
            <span>@WeddingContent.GroomName</span>
            <span class="amp">&amp;</span>
            <span>@WeddingContent.BrideName</span>
        </h1>
        <div class="wd-opening-date">@WeddingContent.DateDisplay</div>
        @* Con dấu sáp mang monogram — nhấn để "bóc dấu" mở thiệp *@
        <button type="button" class="wd-seal-btn" @onclick="OpenAsync">
            <span class="wd-seal">
                <WeddingMonogram Size="58" />
            </span>
            <span class="wd-seal-label">Mở thiệp</span>
        </button>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnOpened { get; set; }

    private bool _closed;

    private async Task OpenAsync()
    {
        _closed = true; // CSS transition tự lo phần fade-out
        await OnOpened.InvokeAsync();
    }
}
