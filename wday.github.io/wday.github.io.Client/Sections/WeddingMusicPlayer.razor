@* Nút nhạc nền nổi. File nhạc: wwwroot/audio/wedding-song.mp3 (xem wwwroot/audio/README.md).
   Nếu chưa có file nhạc, nút tự ẩn. *@
@inject IJSRuntime Js

<audio id="wd-audio" src="audio/wedding-song.mp3" loop preload="none"></audio>

@if (_available)
{
    <button type="button"
            class="wd-music-btn @(_playing ? "is-playing" : null)"
            aria-label="@(_playing ? "Tắt nhạc" : "Bật nhạc")"
            @onclick="ToggleAsync">
        @if (_playing)
        {
            @* Icon nốt nhạc — xoay chậm khi đang phát *@
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
                <path d="M7 15.5 V 4.5 L 16 3 V 13.5" />
                <ellipse cx="5" cy="15.5" rx="2.2" ry="1.8" />
                <ellipse cx="14" cy="13.5" rx="2.2" ry="1.8" />
            </svg>
        }
        else
        {
            @* Icon nốt nhạc gạch chéo — đang tắt *@
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
                <path d="M7 15.5 V 4.5 L 16 3 V 13.5" opacity=".45" />
                <ellipse cx="5" cy="15.5" rx="2.2" ry="1.8" opacity=".45" />
                <ellipse cx="14" cy="13.5" rx="2.2" ry="1.8" opacity=".45" />
                <path d="M3 2 L 17 18" />
            </svg>
        }
    </button>
}

@code {
    private bool _available;
    private bool _playing;

    /// <summary>Gọi khi khách nhấn MỞ THIỆP — bắt đầu phát nhạc trong cùng user gesture.</summary>
    public async Task StartAsync()
    {
        _available = await Js.InvokeAsync<bool>("wedding.audioAvailable", "wd-audio");
        if (_available)
        {
            _playing = await Js.InvokeAsync<bool>("wedding.audioPlay", "wd-audio");
        }
        StateHasChanged();
    }

    private async Task ToggleAsync()
    {
        if (_playing)
        {
            await Js.InvokeVoidAsync("wedding.audioPause", "wd-audio");
            _playing = false;
        }
        else
        {
            _playing = await Js.InvokeAsync<bool>("wedding.audioPlay", "wd-audio");
        }
    }
}
