@* Section 14 — Lời cảm ơn khép lại *@

<section id="final" class="wd-final">
    <img src="@WeddingImages.Final" alt="Ảnh cưới @WeddingContent.CoupleNames" loading="lazy" />
    <div class="wd-final-content" data-reveal="fade-in">
        <div class="wd-final-thanks">Thank You</div>
        <div class="wd-final-names">@WeddingContent.CoupleNames</div>
        <div class="wd-final-date">@WeddingContent.DateDisplay</div>
        <p class="wd-final-quote">&ldquo;@WeddingContent.FinalQuote&rdquo;</p>
    </div>
</section>
