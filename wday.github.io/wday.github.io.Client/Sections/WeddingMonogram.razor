@* Monogram N & L — "chữ ký" lặp lại xuyên suốt thiệp (seal, divider, final).
   Vẽ bằng SVG + font Great Vibes đã load sẵn; màu theo currentColor. *@

<svg class="wd-monogram" width="@Size" height="@Size" viewBox="0 0 100 100" aria-hidden="true">
    <circle cx="50" cy="50" r="47" fill="none" stroke="currentColor" stroke-width="1.1" opacity=".8" />
    <circle cx="50" cy="50" r="42.5" fill="none" stroke="currentColor" stroke-width=".5" opacity=".45" />
    <text x="39" y="60" text-anchor="middle" dominant-baseline="middle"
          font-family="'Great Vibes', cursive" font-size="44" fill="currentColor">N</text>
    <text x="63" y="52" text-anchor="middle" dominant-baseline="middle"
          font-family="'Great Vibes', cursive" font-size="30" fill="currentColor" opacity=".85">L</text>
</svg>

@code {
    [Parameter] public int Size { get; set; } = 56;
}
